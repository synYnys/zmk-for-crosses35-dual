/* crosses_right.overlay */

&spi1 {
    /* 「trackball_central:」というラベルを先頭に追加します */
    trackball_central: trackball_central@0 {
        /* 省略：compatibleなどは既存の設定を維持してください */
        cpi = <1200>;
    };
};

/ {
    trackball_listener {
        compatible = "zmk,input-listener";
        device = <&trackball_central>;
        
        /* 既存のプロセッサ設定を上書きして、スケーラーのみにします。
           これによって、おっしゃる通りレート制限がかからなくなります。
        */
        input-processors = <&zip_xy_scaler 1 1>;
    };
};
